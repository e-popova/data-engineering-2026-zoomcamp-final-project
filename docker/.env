GOOGLE_APPLICATION_CREDENTIALS=/keys/sa_key.json # change file name if needed
GOOGLE_PROJECT_ID=de-zoomcamp2026-final # change to your Google Cloud Project ID
GOOGLE_LOCATION=EU
GCS_BUCKET=gs://crypto-data-full # change to your bucket name (without '/' at the end)
PARTITION_INTERVAL=600 # this is partitioning in GCS in seconds (600).
CHECKPOINT_INTERVAL=60 # checkpoint interval in seconds (60)